{
  "name": "@open-payments-devkit/fixtures",
  "version": "0.1.0",
  "description": "Deterministic requests and Ed25519 key fixtures for the Open Payments HTTP Signatures devkit.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FidelCoder/open-payments-sigkit.git",
    "directory": "packages/fixtures"
  },
  "homepage": "https://github.com/FidelCoder/open-payments-sigkit/tree/main/packages/fixtures",
  "bugs": {
    "url": "https://github.com/FidelCoder/open-payments-sigkit/issues"
  },
  "keywords": [
    "open-payments",
    "fixtures",
    "http-message-signatures",
    "ed25519",
    "conformance"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "keys",
    "requests",
    "vectors"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
