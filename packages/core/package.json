{
  "name": "@open-payments-devkit/core",
  "version": "0.1.0",
  "description": "Core RFC 9421 and Open Payments signing, verification, inspection, and explainer utilities.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FidelCoder/open-payments-sigkit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/FidelCoder/open-payments-sigkit/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/FidelCoder/open-payments-sigkit/issues"
  },
  "keywords": [
    "open-payments",
    "http-message-signatures",
    "rfc9421",
    "content-digest",
    "ed25519",
    "signature-verification"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.1"
  }
}
